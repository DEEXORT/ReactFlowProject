<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd"
        objectQuotingStrategy="QUOTE_ONLY_RESERVED_WORDS">
    <changeSet id="1763660453209-1" author="YuMaSe">
        <createTable tableName="tbl_marker">
            <column autoIncrement="true" name="id" type="BIGINT">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_tbl_marker"/>
            </column>
            <column name="name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>
    <changeSet id="1763660453209-2" author="YuMaSe">
        <createTable tableName="tbl_reaction">
            <column autoIncrement="true" name="id" type="BIGINT">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_tbl_reaction"/>
            </column>
            <column name="topic_id" type="BIGINT"/>
            <column name="content" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>
    <changeSet id="1763660453209-3" author="YuMaSe">
        <createTable tableName="tbl_topic">
            <column autoIncrement="true" name="id" type="BIGINT">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_tbl_topic"/>
            </column>
            <column name="writer_id" type="BIGINT"/>
            <column name="title" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="content" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="created" type="DATETIME"/>
            <column name="modified" type="DATETIME"/>
        </createTable>
    </changeSet>
    <changeSet id="1763660453209-4" author="YuMaSe">
        <createTable tableName="tbl_writer">
            <column autoIncrement="true" name="id" type="BIGINT">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_tbl_writer"/>
            </column>
            <column name="login" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="password" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="firstname" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="lastname" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>
    <changeSet id="1763660453209-5" author="YuMaSe">
        <createTable tableName="topic_marker">
            <column name="marker_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="topic_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>
    <changeSet id="1763660453209-6" author="YuMaSe">
        <addUniqueConstraint columnNames="name" constraintName="uc_tbl_marker_name" tableName="tbl_marker"/>
    </changeSet>
    <changeSet id="1763660453209-7" author="YuMaSe">
        <addUniqueConstraint columnNames="topic_id" constraintName="uc_tbl_reaction_topic" tableName="tbl_reaction"/>
    </changeSet>
    <changeSet id="1763660453209-8" author="YuMaSe">
        <addUniqueConstraint columnNames="title" constraintName="uc_tbl_topic_title" tableName="tbl_topic"/>
    </changeSet>
    <changeSet id="1763660453209-9" author="YuMaSe">
        <addUniqueConstraint columnNames="writer_id" constraintName="uc_tbl_topic_writer" tableName="tbl_topic"/>
    </changeSet>
    <changeSet id="1763660453209-10" author="YuMaSe">
        <addUniqueConstraint columnNames="login" constraintName="uc_tbl_writer_login" tableName="tbl_writer"/>
    </changeSet>
    <changeSet id="1763660453209-11" author="YuMaSe">
        <addForeignKeyConstraint baseColumnNames="topic_id" baseTableName="tbl_reaction"
                                 constraintName="FK_TBL_REACTION_ON_TOPIC" referencedColumnNames="id"
                                 referencedTableName="tbl_topic"/>
    </changeSet>
    <changeSet id="1763660453209-12" author="YuMaSe">
        <addForeignKeyConstraint baseColumnNames="writer_id" baseTableName="tbl_topic"
                                 constraintName="FK_TBL_TOPIC_ON_WRITER" referencedColumnNames="id"
                                 referencedTableName="tbl_writer"/>
    </changeSet>
    <changeSet id="1763660453209-13" author="YuMaSe">
        <addForeignKeyConstraint baseColumnNames="marker_id" baseTableName="topic_marker"
                                 constraintName="fk_topmar_on_marker" referencedColumnNames="id"
                                 referencedTableName="tbl_marker"/>
    </changeSet>
    <changeSet id="1763660453209-14" author="YuMaSe">
        <addForeignKeyConstraint baseColumnNames="topic_id" baseTableName="topic_marker"
                                 constraintName="fk_topmar_on_topic" referencedColumnNames="id"
                                 referencedTableName="tbl_topic"/>
    </changeSet>

</databaseChangeLog>